generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ユーザー情報
model User {
  id            Int           @id @default(autoincrement())
  firebaseUid   String        @unique // Firebase AuthのUID
  name          String
  currentEnergy Float         @default(100.0)
  
  createdEvents Event[]        @relation("EventCreator")
  participating Participant[]
  transactions  Transaction[]
}

// 精算イベント
model Event {
  id             Int           @id @default(autoincrement())
  name           String
  memo           String?
  tag            String?
  invitationCode String        @unique
  totalAmount    Int           @default(0)
  entropy        Float         @default(0.0)
  isClosed       Boolean       @default(false)
  
  // 🌟 onDelete: Cascade は設定せず、作成者が消えてもイベントは残す（または制限する）のが一般的
  creator        User          @relation("EventCreator", fields: [creatorId], references: [firebaseUid])
  creatorId      String

  participants   Participant[]
  transactions   Transaction[]
  createdAt      DateTime      @default(now())

  @@index([creatorId]) // 作成者からの検索を高速化
}

// 参加者管理（中間テーブル）
model Participant {
  id        Int      @id @default(autoincrement())
  // 🌟 イベントが削除されたら、参加記録も自動削除
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   Int
  user      User     @relation(fields: [userUid], references: [firebaseUid])
  userUid   String
  joinedAt  DateTime @default(now())

  @@unique([eventId, userUid])
  @@index([userUid]) // ユーザーが参加しているイベント一覧を出す時に高速化
}

// 支払い履歴
model Transaction {
  id                Int      @id @default(autoincrement())
  amount            Int
  description       String
  activationEnergy  Float    @default(10.0)
  
  payer             User     @relation(fields: [payerUid], references: [firebaseUid])
  payerUid          String
  
  // 🌟 イベントが削除されたら、支払い履歴も自動削除
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId           Int
  createdAt         DateTime @default(now())

  @@index([eventId])  // 精算計算（ロジック実行）のたびに検索するので必須
  @@index([payerUid])
}

model Friend {
  id        Int      @id @default(autoincrement())
  userUid   String   
  friendUid String   
  status    String   @default("PENDING") 
  createdAt DateTime @default(now())

  @@unique([userUid, friendUid])
  @@index([userUid])   // フレンドリスト表示の高速化
  @@index([friendUid])
}